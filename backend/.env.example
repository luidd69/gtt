# ===================================================
# GTT Backend — Configurazione ambiente
# Copiare in .env e personalizzare i valori
# ===================================================

PORT=3001
NODE_ENV=development

# ---------------------------------------------------
# GTFS STATICO
# URL del feed GTFS ufficiale GTT (file .zip)
# Verificare l'URL aggiornato su:
#   https://www.gtt.to.it/cms/percorari-e-tariffe/gtfs
# oppure su Open Data Torino:
#   https://opendata.comune.torino.it/
# ---------------------------------------------------
GTFS_STATIC_URL=https://www.gtt.to.it/gtfs/google_transit.zip

# Cartella locale dove salvare/estrarre il GTFS
GTFS_DATA_DIR=./data/gtfs

# Aggiornamento automatico GTFS (cron expression)
# Default: ogni giorno alle 03:00
GTFS_REFRESH_CRON=0 3 * * *

# ---------------------------------------------------
# GTFS REALTIME
# NOTA: GTT non dispone di un feed GTFS-RT pubblico
# documentato. Lasciare vuoto per disabilitare.
# Se in futuro disponibile, impostare l'URL qui.
# ---------------------------------------------------
GTFS_REALTIME_URL=
GTFS_REALTIME_REFRESH_SECONDS=30

# ---------------------------------------------------
# CACHE
# Durata cache risposte API (in secondi)
# ---------------------------------------------------
CACHE_TTL_ARRIVALS=30
CACHE_TTL_STOPS=300
CACHE_TTL_LINES=600
CACHE_TTL_NEARBY=15

# ---------------------------------------------------
# CORS
# Origini permesse per il frontend
# ---------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
